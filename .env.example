# Kagujje Ecosystem - Environment Variables
# Copy this to .env and fill in the values

# ===========================================
# KAI CREDENTIALS (Store in Zo Secrets)
# ===========================================

# GitHub
KAI_GITHUB_TOKEN=your_github_token_here

# Telegram API
KAI_TELEGRAM_API_ID=your_api_id_here
KAI_TELEGRAM_API_HASH=your_api_hash_here
KAI_TELEGRAM_BOT_TOKEN=your_bot_token_here

# ===========================================
# SERVICES
# ===========================================

# Supabase
SUPABASE_URL=https://dtejfdquiqogwapjtfar.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Gateway
AI_GATEWAY_URL=https://kagujje-ai-gateway.vercel.app/v1

# ===========================================
# OPTIONAL PROVIDERS
# ===========================================

# Groq (Fast Inference)
GROQ_API_KEY=your_groq_key_here

# OpenRouter (Unlimited Models)
OPENROUTER_API_KEY=your_openrouter_key_here

# ===========================================
# EMERGENCY CONTACTS
# ===========================================

OWNER_EMAIL=nomad.dxb2@gmail.com
OWNER_TELEGRAM=@dicksonkagujje

# KAI Identity
KAI_NAME=Kagujje AI
KAI_VERSION=1.0.0
